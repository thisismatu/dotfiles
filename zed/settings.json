// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  // Assistant
  "edit_predictions": {
    "provider": "copilot",
    "disabled_globs": [
      "**/.env*",
      "**/*.pem",
      "**/*.key",
      "**/*.cert",
      "**/*.crt",
      "**/secrets.yml",
    ],
    "mode": "subtle",
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "default_profile": "ask",
    "default_model": {
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5",
    },
    "default_width": 640,
  },
  // UI
  "cli_default_open_behavior": "existing_window",
  "excerpt_context_lines": 3,
  "expand_excerpt_lines": 5,
  "theme": "One Dark",
  "ui_font_size": 16,
  "ui_font_family": "Inter Variable",
  "buffer_font_size": 14,
  "buffer_font_family": "Meslo LG S",
  "scrollbar": {
    "axes": {
      "horizontal": false,
    },
  },
  "tabs": {
    "git_status": true,
    "activate_on_close": "left_neighbour",
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
  },
  "project_panel": {
    "dock": "left",
    "default_width": 320,
  },
  "git_panel": {
    "dock": "left",
    "default_width": 320,
  },
  "outline_panel": {
    "dock": "left",
    "default_width": 320,
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "journal": {
    "path": "~/My Drive",
    "hour_format": "hour24",
  },
  "terminal": {
    "cursor_shape": "bar",
    "line_height": "standard",
  },
  // Writing
  "vim_mode": false,
  "base_keymap": "VSCode",
  "tab_size": 2,
  "soft_wrap": "editor_width",
  "cursor_blink": false,
  "autosave": "on_window_change",
  "format_on_save": "on",
  "extend_comment_on_newline": false,
  "lsp_highlight_debounce": 50,
  "preferred_line_length": 100,
  // Languages & files
  "languages": {
    "Markdown": {
      "format_on_save": "off",
      "remove_trailing_whitespace_on_save": false,
    },
    "XML": {
      "preferred_line_length": 500,
    },
    "PHP": {
      "formatter": {
        "external": {
          "command": "/usr/local/bin/php-format",
          "arguments": ["{buffer_path}"],
        },
      },
    },
    "Ruby": {
      "tab_size": 2,
      "language_servers": ["ruby-lsp", "rubocop", "tailwindcss-language-server", "!solargraph"],
      "formatter": "language_server",
    },
    "HTML/ERB": {
      "tab_size": 2,
      "language_servers": ["ruby-lsp", "tailwindcss-language-server", "emmet-language-server"],
      "formatter": {
        "external": {
          "command": "erb-formatter",
          "arguments": ["--stdin-filename", "{buffer_path}"],
        },
      },
      // Previous version, works with tailwind auto sort tags
      // "formatter": {
      //   "external": {
      //     "command": "erb-formatter",
      //     "arguments": [
      //       "--stdin",
      //       "--tailwind-output-path", // Comment out if on non-tailwind project
      //       "app/assets/builds/tailwind.css" // Generate this by running bin/rails tailwindcss:build
      //     ]
      //   }
      // }
    },
  },
  "file_types": {
    "Blade": ["*.blade.php"],
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "erb": "html",
          "ruby": "html",
        },
        "experimental": {
          "classRegex": ["\\bclass:\\s*'([^']*)'", "\\bclass:\\s*\"([^\"]*)\""],
        },
      },
    },
  },
}
